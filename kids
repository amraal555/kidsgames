<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌈 KidooLand – 5 fun learning games for age 5+</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none; /* prevent accidental selection while tapping */
            font-family: 'Comic Sans MS', 'Chalkboard SE', 'Arial Rounded', sans-serif;
        }
        body {
            background: linear-gradient(145deg, #ffe7b9, #ffcf8a);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
            margin: 0;
        }
        .game-container {
            width: 1100px;
            max-width: 100%;
            background: #fef9e4;
            border-radius: 60px 60px 40px 40px;
            box-shadow: 0 20px 30px rgba(0,0,0,0.2), inset 0 2px 10px #fff9;
            padding: 30px 20px;
            border: 6px solid #ffb347;
        }
        /* ----- MAIN MENU STYLES ----- */
        #main-menu {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        h1 {
            font-size: 4rem;
            color: #d64e12;
            text-shadow: 4px 4px 0 #ffd966, 6px 6px 0 rgba(0,0,0,0.1);
            margin-top: 0;
            margin-bottom: 10px;
            letter-spacing: 2px;
        }
        .total-score-badge {
            background: #6b8cff;
            padding: 20px 40px;
            border-radius: 60px;
            font-size: 2.5rem;
            font-weight: bold;
            color: white;
            text-shadow: 2px 2px 0 #003b6f;
            box-shadow: 0 8px 0 #2a4b9e, inset 0 4px 10px #b3ceff;
            margin-bottom: 30px;
            display: inline-block;
            border: 3px solid #ffd966;
        }
        .menu-instruction {
            font-size: 2rem;
            background: #ffb882;
            color: #2d1b0a;
            padding: 15px 30px;
            border-radius: 40px;
            margin-bottom: 30px;
            box-shadow: 0 5px 0 #b25f00;
        }
        .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
            gap: 20px;
            width: 100%;
            margin: 20px 0;
        }
        .game-card {
            background: #fddd9e;
            border: 5px solid #fb8b2c;
            border-radius: 50px;
            padding: 25px 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            font-size: 1.8rem;
            font-weight: bold;
            color: #3f2b0f;
            box-shadow: 0 10px 0 #bb5f00, 0 8px 15px rgba(0,0,0,0.2);
            transition: 0.07s;
            cursor: pointer;
            background: radial-gradient(circle at 30% 20%, #fff4cb, #fdcc8a);
        }
        .game-card:active {
            transform: translateY(7px);
            box-shadow: 0 3px 0 #bb5f00;
        }
        .game-icon {
            font-size: 4.5rem;
            filter: drop-shadow(2px 6px 0 #c05f00);
        }
        /* ----- GAME HEADER (common) ----- */
        .game-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #a4d7ff;
            padding: 15px 25px;
            border-radius: 50px;
            margin-bottom: 25px;
            border: 4px solid #2475b0;
            flex-wrap: wrap;
        }
        .lives span {
            font-size: 2.4rem;
            margin-right: 5px;
            color: #ff3b3b;
            filter: drop-shadow(0 2px 2px darkred);
        }
        .score-box {
            background: gold;
            font-size: 2rem;
            padding: 10px 25px;
            border-radius: 40px;
            font-weight: bold;
            border: 3px solid #b47d00;
        }
        .game-header button {
            background: white;
            border: none;
            font-size: 1.7rem;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: bold;
            cursor: pointer;
            border: 3px solid #3f8f3f;
            box-shadow: 0 5px 0 #1b5e1b;
            transition: 0.05s linear;
        }
        .game-header button:active {
            transform: translateY(4px);
            box-shadow: 0 1px 0 #1b5e1b;
        }
        /* ----- GAME AREA ----- */
        .question-box {
            background: #fef5cf;
            padding: 25px;
            border-radius: 70px;
            font-size: 3rem;
            text-align: center;
            border: 5px dashed #ff8c42;
            margin-bottom: 30px;
            font-weight: bold;
        }
        .options-area {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            margin: 30px 0;
        }
        .option-btn {
            min-width: 150px;
            padding: 25px 15px;
            font-size: 2.2rem;
            background: #b0e0ff;
            border: 5px solid #2f6f9f;
            border-radius: 60px;
            font-weight: bold;
            color: #042233;
            box-shadow: 0 8px 0 #144a6f;
            cursor: pointer;
            transition: 0.05s;
            flex: 0 1 auto;
            text-align: center;
        }
        .option-btn:active {
            transform: translateY(6px);
            box-shadow: 0 2px 0 #144a6f;
        }
        .option-btn.disabled, .option-btn:disabled {
            opacity: 0.5;
            pointer-events: none;
            transform: none;
        }
        .feedback-msg {
            font-size: 2.2rem;
            min-height: 4rem;
            color: #b34180;
            background: #fff8d6;
            padding: 15px;
            border-radius: 30px;
            border: 3px solid orange;
            margin: 15px 0;
            text-align: center;
        }
        .back-btn {
            background: #b19cd9 !important;
            border-color: #4b2f82 !important;
            box-shadow: 0 5px 0 #351f5c !important;
        }
        .special-task {
            font-size: 2.5rem;
            background: #d9f0b5;
            padding: 30px;
            border-radius: 50px;
            border: 5px solid #7bac2d;
        }
        /* drag example for game4 */
        .drag-area {
            display: flex;
            justify-content: center;
            gap: 50px;
            margin: 30px 0;
            align-items: center;
        }
        .draggable {
            width: 120px;
            height: 120px;
            background: #f55c5c;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            border-radius: 20px;
            border: 4px solid white;
            cursor: grab;
        }
        .dropzone {
            width: 150px;
            height: 150px;
            background: #66cc99;
            border: 6px dashed #1f7a5a;
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }
        /* shapes game */
        .shape-preview {
            display: inline-block;
            width: 80px;
            height: 80px;
            margin: 0 10px;
        }
        .circle { border-radius: 50%; }
        .square { border-radius: 10px; }
        .triangle {
            width: 0; height: 0;
            border-left: 40px solid transparent;
            border-right: 40px solid transparent;
            border-bottom: 70px solid red;
            background: none !important;
        }
        /* hide all games by default, menu visible */
        .game-screen {
            display: none;
        }
        .visible {
            display: block;
        }
    </style>
</head>
<body>
<div class="game-container" id="app-container">
    <!-- MAIN MENU -->
    <div id="main-menu">
        <h1>🎈 KidooLand 🎈</h1>
        <div class="total-score-badge" id="total-score-display">🏆 0</div>
        <div class="menu-instruction">👇 Click a game to start learning! 👇</div>
        <div class="games-grid">
            <div class="game-card" data-game="game1"><span class="game-icon">🧮</span> Math whiz</div>
            <div class="game-card" data-game="game2"><span class="game-icon">🔤</span> ABC fun</div>
            <div class="game-card" data-game="game3"><span class="game-icon">🔢</span> Count it</div>
            <div class="game-card" data-game="game4"><span class="game-icon">🖱️</span> Mouse & keys</div>
            <div class="game-card" data-game="game5"><span class="game-icon">🔴🔷</span> Shapes & colors</div>
        </div>
    </div>

    <!-- GAME 1: MATH (addition/subtraction) -->
    <div id="game1" class="game-screen">
        <div class="game-header"><div class="lives" id="game1-lives">❤️❤️❤️</div><div class="score-box" id="game1-score">0</div><div><button id="game1-reset">🔄 Reset</button><button class="back-btn" data-back="game1">🔙 Back</button></div></div>
        <div class="question-box" id="game1-question">2 + 2 = ?</div>
        <div class="options-area" id="game1-options"></div>
        <div class="feedback-msg" id="game1-feedback"></div>
    </div>

    <!-- GAME 2: ENGLISH (alphabet & words) -->
    <div id="game2" class="game-screen">
        <div class="game-header"><div class="lives" id="game2-lives">❤️❤️❤️</div><div class="score-box" id="game2-score">0</div><div><button id="game2-reset">🔄 Reset</button><button class="back-btn" data-back="game2">🔙 Back</button></div></div>
        <div class="question-box" id="game2-question">Find the letter A</div>
        <div class="options-area" id="game2-options"></div>
        <div class="feedback-msg" id="game2-feedback"></div>
    </div>

    <!-- GAME 3: NUMBERS RECOGNITION (dots) -->
    <div id="game3" class="game-screen">
        <div class="game-header"><div class="lives" id="game3-lives">❤️❤️❤️</div><div class="score-box" id="game3-score">0</div><div><button id="game3-reset">🔄 Reset</button><button class="back-btn" data-back="game3">🔙 Back</button></div></div>
        <div class="question-box" id="game3-question">Number 3 → how many dots?</div>
        <div class="options-area" id="game3-options"></div>
        <div class="feedback-msg" id="game3-feedback"></div>
    </div>

    <!-- GAME 4: BASIC COMPUTER SKILLS -->
    <div id="game4" class="game-screen">
        <div class="game-header"><div class="lives" id="game4-lives">❤️❤️❤️</div><div class="score-box" id="game4-score">0</div><div><button id="game4-reset">🔄 Reset</button><button class="back-btn" data-back="game4">🔙 Back</button></div></div>
        <div class="question-box" id="game4-task">⭐ Click the star!</div>
        <div id="game4-playground" style="min-height:250px;"></div>
        <div class="feedback-msg" id="game4-feedback"></div>
    </div>

    <!-- GAME 5: SHAPES & COLORS -->
    <div id="game5" class="game-screen">
        <div class="game-header"><div class="lives" id="game5-lives">❤️❤️❤️</div><div class="score-box" id="game5-score">0</div><div><button id="game5-reset">🔄 Reset</button><button class="back-btn" data-back="game5">🔙 Back</button></div></div>
        <div class="question-box" id="game5-question">Find the red circle</div>
        <div class="options-area" id="game5-options"></div>
        <div class="feedback-msg" id="game5-feedback"></div>
    </div>
</div>

<script>
    (function(){
        // ---------- GLOBAL STATE & LOCALSTORAGE ----------
        let gameScores = { game1:0, game2:0, game3:0, game4:0, game5:0 };
        const totalSpan = document.getElementById('total-score-display');
        function loadScores() {
            const stored = localStorage.getItem('kidooScores');
            if(stored) {
                try { gameScores = JSON.parse(stored); } catch(e){}
            }
            updateTotalDisplay();
        }
        function saveScores() {
            localStorage.setItem('kidooScores', JSON.stringify(gameScores));
        }
        function updateTotalDisplay() {
            let total = Object.values(gameScores).reduce((a,b)=>a+b,0);
            totalSpan.innerText = '🏆 ' + total;
        }

        // Helper: update game score and total, refresh UI
        function setGameScore(gameId, newScore) {
            gameScores[gameId] = Math.max(0, newScore);
            saveScores();
            updateTotalDisplay();
            // update that game's score display
            const scoreEl = document.getElementById(gameId+'-score');
            if(scoreEl) scoreEl.innerText = gameScores[gameId];
        }

        // ---------- GAME MANAGER: switch screens ----------
        const menu = document.getElementById('main-menu');
        const gameScreens = document.querySelectorAll('.game-screen');
        function showMenu() {
            menu.style.display = 'flex';
            gameScreens.forEach(g => g.style.display = 'none');
        }
        function showGame(gameId) {
            menu.style.display = 'none';
            gameScreens.forEach(g => g.style.display = 'none');
            const active = document.getElementById(gameId);
            if(active) active.style.display = 'block';
        }

        // attach menu card listeners
        document.querySelectorAll('.game-card').forEach(card => {
            card.addEventListener('click', (e) => {
                const game = card.dataset.game; // "game1" etc
                showGame(game);
                // Initialize / refresh that game
                if(window[`initGame${game[4]}`]) window[`initGame${game[4]}`](); // initGame1, initGame2 ...
            });
        });
        // back buttons
        document.querySelectorAll('.back-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                showMenu();
            });
        });

        // ---------- GAME 1 (MATH) ----------
        let g1State = { lives:3, qIndex:0, questions:[], active:true };
        function generateMathQuestion() {
            let a = Math.floor(Math.random()*9)+1; // 1-9
            let b = Math.floor(Math.random()*9)+1;
            let op = Math.random()<0.5 ? '+' : '-';
            let correct;
            if(op === '+') correct = a+b;
            else {
                if(a<b) [a,b]=[b,a]; // avoid negative
                correct = a-b;
            }
            let options = [correct];
            while(options.length < 3) {
                let fake = correct + (Math.floor(Math.random()*5)-2);
                if(fake>=0 && fake<=10 && !options.includes(fake)) options.push(fake);
            }
            options = options.sort(()=>Math.random()-0.5);
            return { question:`${a} ${op} ${b} = ?`, correct, options };
        }
        function refreshGame1() {
            if(!g1State.active) return;
            const q = g1State.questions[g1State.qIndex];
            document.getElementById('game1-question').innerText = q.question;
            const optsDiv = document.getElementById('game1-options');
            optsDiv.innerHTML = '';
            q.options.forEach(opt => {
                let btn = document.createElement('button');
                btn.classList.add('option-btn');
                btn.innerText = opt;
                btn.addEventListener('click', (e) => handleGame1Answer(opt, q.correct));
                optsDiv.appendChild(btn);
            });
        }
        function handleGame1Answer(selected, correct) {
            if(!g1State.active) return;
            if(selected === correct) {
                // correct
                document.getElementById('game1-feedback').innerText = '✅ Great job!';
                let newScore = gameScores.game1 + 1;
                setGameScore('game1', newScore);
                // move to next question
                g1State.qIndex++;
                if(g1State.qIndex >= 5) {
                    document.getElementById('game1-feedback').innerText = `✨ You did 5 questions! Score: ${gameScores.game1}`;
                    g1State.active = false; // end
                    document.querySelectorAll('#game1-options .option-btn').forEach(b=>b.disabled=true);
                    return;
                }
                refreshGame1();
            } else {
                // wrong
                document.getElementById('game1-feedback').innerText = '😓 Try again!';
                g1State.lives--;
                const hearts = '❤️'.repeat(g1State.lives) + '🖤'.repeat(3-g1State.lives);
                document.getElementById('game1-lives').innerText = hearts;
                if(g1State.lives <= 0) {
                    document.getElementById('game1-feedback').innerText = '💔 Game over. Press Reset.';
                    g1State.active = false;
                    document.querySelectorAll('#game1-options .option-btn').forEach(b=>b.disabled=true);
                }
            }
        }
        window.initGame1 = function() {
            g1State = { lives:3, qIndex:0, questions:[], active:true };
            for(let i=0;i<5;i++) g1State.questions.push(generateMathQuestion());
            document.getElementById('game1-lives').innerText = '❤️❤️❤️';
            document.getElementById('game1-score').innerText = gameScores.game1;
            document.getElementById('game1-feedback').innerText = '';
            refreshGame1();
        };
        document.getElementById('game1-reset').addEventListener('click', ()=>{
            setGameScore('game1', 0);
            window.initGame1();
        });

        // ---------- GAME 2 (ENGLISH alphabet & words) quick version ----------
        let g2State = { lives:3, qIndex:0, questions:[], active:true };
        function generateEnglishTask() {
            if(Math.random()<0.5) { // letter
                let letters = ['A','B','C','D','E','F','G'];
                let correct = letters[Math.floor(Math.random()*letters.length)];
                let others = letters.filter(l=>l!==correct).sort(()=>0.5-Math.random()).slice(0,2);
                let options = [correct, ...others].sort(()=>0.5-Math.random());
                return { question:`Find the letter ${correct}`, correct, options };
            } else { // word with emoji
                let words = [ {emoji:'🐱', word:'CAT'}, {emoji:'🐶', word:'DOG'}, {emoji:'🐭', word:'MOUSE'}, {emoji:'🐮', word:'COW'} ];
                let pick = words[Math.floor(Math.random()*words.length)];
                let correct = pick.word;
                let otherWords = words.filter(w=>w.word!==correct).map(w=>w.word).sort(()=>0.5-Math.random()).slice(0,2);
                let options = [correct, ...otherWords].sort(()=>0.5-Math.random());
                return { question:`${pick.emoji} Which word?`, correct, options };
            }
        }
        function refreshGame2() {
            if(!g2State.active) return;
            let q = g2State.questions[g2State.qIndex];
            document.getElementById('game2-question').innerText = q.question;
            let optsDiv = document.getElementById('game2-options');
            optsDiv.innerHTML = '';
            q.options.forEach(opt => {
                let btn = document.createElement('button');
                btn.classList.add('option-btn');
                btn.innerText = opt;
                btn.addEventListener('click', ()=> handleGame2Answer(opt, q.correct));
                optsDiv.appendChild(btn);
            });
        }
        function handleGame2Answer(selected, correct) {
            if(!g2State.active) return;
            if(selected === correct) {
                document.getElementById('game2-feedback').innerText = '⭐ Awesome!';
                setGameScore('game2', gameScores.game2+1);
                g2State.qIndex++;
                if(g2State.qIndex>=5) {
                    document.getElementById('game2-feedback').innerText = `🎉 5 done! Score: ${gameScores.game2}`;
                    g2State.active = false; document.querySelectorAll('#game2-options .option-btn').forEach(b=>b.disabled=true);
                    return;
                }
                refreshGame2();
            } else {
                document.getElementById('game2-feedback').innerText = '🤔 Oops! try again.';
                g2State.lives--;
                document.getElementById('game2-lives').innerText = '❤️'.repeat(g2State.lives)+'🖤'.repeat(3-g2State.lives);
                if(g2State.lives<=0) {
                    document.getElementById('game2-feedback').innerText = '💔 No lives left.';
                    g2State.active = false; document.querySelectorAll('#game2-options .option-btn').forEach(b=>b.disabled=true);
                }
            }
        }
        window.initGame2 = function() {
            g2State = { lives:3, qIndex:0, questions:[], active:true };
            for(let i=0;i<5;i++) g2State.questions.push(generateEnglishTask());
            document.getElementById('game2-lives').innerText = '❤️❤️❤️';
            document.getElementById('game2-score').innerText = gameScores.game2;
            document.getElementById('game2-feedback').innerText = '';
            refreshGame2();
        };
        document.getElementById('game2-reset').addEventListener('click', ()=>{
            setGameScore('game2',0); window.initGame2();
        });

        // ---------- GAME 3 (Numbers with dots) ----------
        let g3State = { lives:3, qIndex:0, questions:[], active:true };
        function generateDotQuestion() {
            let number = Math.floor(Math.random()*5)+1; // 1-5
            let correct = number;
            let options = [correct];
            while(options.length<3){
                let fake = Math.floor(Math.random()*5)+1;
                if(!options.includes(fake)) options.push(fake);
            }
            options = options.sort(()=>Math.random()-0.5);
            return { question:`Number ${number} (choose dots)`, correct, options };
        }
        function renderDots(count) {
            return '🔵'.repeat(count);
        }
        function refreshGame3() {
            if(!g3State.active) return;
            let q = g3State.questions[g3State.qIndex];
            document.getElementById('game3-question').innerText = q.question;
            let optsDiv = document.getElementById('game3-options');
            optsDiv.innerHTML = '';
            q.options.forEach(opt => {
                let btn = document.createElement('button');
                btn.classList.add('option-btn');
                btn.innerText = renderDots(opt);
                btn.addEventListener('click', ()=> handleGame3Answer(opt, q.correct));
                optsDiv.appendChild(btn);
            });
        }
        function handleGame3Answer(selected, correct) {
            if(!g3State.active) return;
            if(selected === correct) {
                document.getElementById('game3-feedback').innerText = '🎈 Perfect!';
                setGameScore('game3', gameScores.game3+1);
                g3State.qIndex++;
                if(g3State.qIndex>=5) {
                    document.getElementById('game3-feedback').innerText = `🎊 Great! Score: ${gameScores.game3}`;
                    g3State.active = false; document.querySelectorAll('#game3-options .option-btn').forEach(b=>b.disabled=true);
                    return;
                }
                refreshGame3();
            } else {
                document.getElementById('game3-feedback').innerText = '😕 Not that one.';
                g3State.lives--;
                document.getElementById('game3-lives').innerText = '❤️'.repeat(g3State.lives)+'🖤'.repeat(3-g3State.lives);
                if(g3State.lives<=0) {
                    document.getElementById('game3-feedback').innerText = '💔 Game over.';
                    g3State.active = false; document.querySelectorAll('#game3-options .option-btn').forEach(b=>b.disabled=true);
                }
            }
        }
        window.initGame3 = function() {
            g3State = { lives:3, qIndex:0, questions:[], active:true };
            for(let i=0;i<5;i++) g3State.questions.push(generateDotQuestion());
            document.getElementById('game3-lives').innerText = '❤️❤️❤️';
            document.getElementById('game3-score').innerText = gameScores.game3;
            document.getElementById('game3-feedback').innerText = '';
            refreshGame3();
        };
        document.getElementById('game3-reset').addEventListener('click', ()=>{
            setGameScore('game3',0); window.initGame3();
        });

        // ---------- GAME 4 (computer skills) simplified with tasks ----------
        let g4State = { lives:3, taskIndex:0, tasks:[], active:true, listening:false };
        function buildTaskList() {
            return [
                { type:'click', target:'star', description:'⭐ Click the star!', element:'<div id="star-target" style="font-size:5rem;cursor:pointer;">⭐</div>' },
                { type:'key', key:'a', description:'⌨️ Press letter A on keyboard' },
                { type:'click', target:'blueCircle', description:'🔵 Click the blue circle', element:'<div id="blueCircle" style="width:100px;height:100px;background:#3b9eff;border-radius:50%;margin:auto;"></div>' },
                { type:'key', key:' ', description:'␣ Press the spacebar' },
                { type:'drag', description:'🟥 Drag red square to green drop', dragEl:'square', dropEl:'drop' }
            ];
        }
        function renderGame4Task() {
            if(!g4State.active) return;
            let task = g4State.tasks[g4State.taskIndex];
            document.getElementById('game4-task').innerText = task.description;
            let pg = document.getElementById('game4-playground');
            pg.innerHTML = '';
            if(task.type === 'click' && task.element) {
                pg.innerHTML = task.element;
                if(task.target === 'star') {
                    document.getElementById('star-target')?.addEventListener('click', ()=> handleGame4Correct());
                } else if(task.target === 'blueCircle') {
                    document.getElementById('blueCircle')?.addEventListener('click', ()=> handleGame4Correct());
                }
            } else if(task.type === 'drag') {
                pg.innerHTML = `<div class="drag-area"><div id="dragSquare" class="draggable" draggable="true">🔲</div><div id="dropZone" class="dropzone">DROP</div></div>`;
                let drag = document.getElementById('dragSquare');
                let drop = document.getElementById('dropZone');
                drag.addEventListener('dragstart', e=> e.dataTransfer.setData('text/plain','square'));
                drop.addEventListener('dragover', e=> e.preventDefault());
                drop.addEventListener('drop', e=> {
                    e.preventDefault();
                    if(e.dataTransfer.getData('text/plain')==='square') handleGame4Correct();
                });
            } else if(task.type === 'key') {
                pg.innerHTML = '<div style="font-size:2rem;padding:30px;">👂 listen for key...</div>';
            }
        }
        function handleGame4Correct() {
            if(!g4State.active) return;
            document.getElementById('game4-feedback').innerText = '🎯 Super!';
            setGameScore('game4', gameScores.game4+1);
            g4State.taskIndex++;
            if(g4State.taskIndex >= g4State.tasks.length) {
                document.getElementById('game4-feedback').innerText = `🎉 All done! Score: ${gameScores.game4}`;
                g4State.active = false; return;
            }
            renderGame4Task();
        }
        function handleGame4Wrong() {
            if(!g4State.active) return;
            document.getElementById('game4-feedback').innerText = '😲 try again';
            g4State.lives--;
            document.getElementById('game4-lives').innerText = '❤️'.repeat(g4State.lives)+'🖤'.repeat(3-g4State.lives);
            if(g4State.lives<=0) {
                document.getElementById('game4-feedback').innerText = '💔 oh no!';
                g4State.active = false;
            }
        }
        window.initGame4 = function() {
            g4State = { lives:3, taskIndex:0, tasks:buildTaskList(), active:true };
            document.getElementById('game4-lives').innerText = '❤️❤️❤️';
            document.getElementById('game4-score').innerText = gameScores.game4;
            document.getElementById('game4-feedback').innerText = '';
            renderGame4Task();
        };
        document.getElementById('game4-reset').addEventListener('click', ()=>{
            setGameScore('game4',0); window.initGame4();
        });
        window.addEventListener('keydown', (e) => {
            if(!g4State.active || document.getElementById('game4').style.display!=='block') return;
            let task = g4State.tasks[g4State.taskIndex];
            if(task && task.type==='key') {
                if((task.key===' ' && e.code==='Space') || e.key.toLowerCase()===task.key) {
                    handleGame4Correct();
                } else {
                    handleGame4Wrong();
                }
            }
        });

        // ---------- GAME 5 (shapes & colors) ----------
        let g5State = { lives:3, qIndex:0, questions:[], active:true };
        function generateShapeQuestion() {
            let colors = ['red','blue','green','gold'];
            let shapes = ['circle','square','triangle'];
            let col = colors[Math.floor(Math.random()*colors.length)];
            let shape = shapes[Math.floor(Math.random()*shapes.length)];
            let correct = col+'-'+shape;
            let options = [correct];
            while(options.length<4) {
                let rcol = colors[Math.floor(Math.random()*colors.length)];
                let rshape = shapes[Math.floor(Math.random()*shapes.length)];
                let fake = rcol+'-'+rshape;
                if(!options.includes(fake)) options.push(fake);
            }
            options = options.sort(()=>0.5-Math.random());
            return { question:`Find the ${col} ${shape}`, correct, options };
        }
        function renderShapeOption(opt) {
            let [col, shape] = opt.split('-');
            let shapeDiv = document.createElement('div');
            shapeDiv.classList.add('shape-preview', shape);
            if(shape!=='triangle') shapeDiv.style.backgroundColor = col;
            else {
                shapeDiv.style.borderBottomColor = col; // triangle colored via border
            }
            return shapeDiv;
        }
        function refreshGame5() {
            if(!g5State.active) return;
            let q = g5State.questions[g5State.qIndex];
            document.getElementById('game5-question').innerText = q.question;
            let optsDiv = document.getElementById('game5-options');
            optsDiv.innerHTML = '';
            q.options.forEach(opt => {
                let btn = document.createElement('button');
                btn.classList.add('option-btn');
                btn.innerHTML = ''; 
                btn.appendChild(renderShapeOption(opt));
                btn.addEventListener('click', ()=> handleGame5Answer(opt, q.correct));
                optsDiv.appendChild(btn);
            });
        }
        function handleGame5Answer(selected, correct) {
            if(!g5State.active) return;
            if(selected === correct) {
                document.getElementById('game5-feedback').innerText = '🌈 Yay!';
                setGameScore('game5', gameScores.game5+1);
                g5State.qIndex++;
                if(g5State.qIndex>=5) {
                    document.getElementById('game5-feedback').innerText = `🎨 finished! Score: ${gameScores.game5}`;
                    g5State.active = false; document.querySelectorAll('#game5-options .option-btn').forEach(b=>b.disabled=true);
                    return;
                }
                refreshGame5();
            } else {
                document.getElementById('game5-feedback').innerText = '😌 Not that.';
                g5State.lives--;
                document.getElementById('game5-lives').innerText = '❤️'.repeat(g5State.lives)+'🖤'.repeat(3-g5State.lives);
                if(g5State.lives<=0) {
                    document.getElementById('game5-feedback').innerText = '💔 Game over.';
                    g5State.active = false; document.querySelectorAll('#game5-options .option-btn').forEach(b=>b.disabled=true);
                }
            }
        }
        window.initGame5 = function() {
            g5State = { lives:3, qIndex:0, questions:[], active:true };
            for(let i=0;i<5;i++) g5State.questions.push(generateShapeQuestion());
            document.getElementById('game5-lives').innerText = '❤️❤️❤️';
            document.getElementById('game5-score').innerText = gameScores.game5;
            document.getElementById('game5-feedback').innerText = '';
            refreshGame5();
        };
        document.getElementById('game5-reset').addEventListener('click', ()=>{
            setGameScore('game5',0); window.initGame5();
        });

        // start: load scores and show menu
        loadScores();
        showMenu();
        // pre-initialize games for first open (optional)
        window.initGame1(); window.initGame2(); window.initGame3(); window.initGame4(); window.initGame5();
    })();
</script>
